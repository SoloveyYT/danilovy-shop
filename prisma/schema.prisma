// Схема БД: ювелирный маркетплейс «Мастерская Даниловых»
// Prisma защищает от SQL-инъекций через параметризованные запросы

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  ADMIN
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  READY
  ISSUED
}

enum DeliveryMethod {
  PICKUP
  COURIER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
}

enum OrderItemType {
  SERVICE
  CATALOG
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

/// Услуги ремонта и сопутствующие позиции
model Service {
  id          String   @id @default(cuid())
  article     String   @unique
  title       String
  description String   @default("")
  price       Decimal  @db.Decimal(12, 2)
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Изделия из каталога серебра (размеры и камни — JSON-массивы опций)
model CatalogItem {
  id          String   @id @default(cuid())
  article     String   @unique
  title       String
  description String   @default("")
  basePrice   Decimal  @db.Decimal(12, 2)
  /// [{ "label": "17", "modifier": "0" }, ...]
  sizesJson   String   @default("[]")
  /// [{ "name": "Фианит", "modifier": "500" }, ...]
  stonesJson  String   @default("[]")
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            OrderStatus    @default(NEW)
  deliveryMethod    DeliveryMethod
  courierFee        Decimal        @db.Decimal(12, 2)
  subtotal          Decimal        @db.Decimal(12, 2)
  total             Decimal        @db.Decimal(12, 2)
  customerName      String
  phone             String
  email             String
  address           String         @default("")
  comment           String         @default("")
  paymentStatus     PaymentStatus  @default(PENDING)
  yookassaPaymentId String?
  /// Пока админ не открыл список заказов — считается «новым» для бейджа
  viewedByAdmin     Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  items             OrderItem[]
}

model OrderItem {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType      OrderItemType
  serviceId     String?
  catalogItemId String?
  title         String
  quantity      Int           @default(1)
  unitPrice     Decimal       @db.Decimal(12, 2)
  selectedSize  String?
  selectedStone String?
  createdAt     DateTime      @default(now())
}

/// Ключ-значение: контакты, график, фикс. стоимость курьера и т.д.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
